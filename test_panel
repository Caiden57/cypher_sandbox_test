<script>
// ══════════════════════════════════════════════════════════════
// CYPHER SCANNER SANDBOX — Conviction Engine (standalone port)
// All math extracted from 07_scanner.js, no live API calls.
// ══════════════════════════════════════════════════════════════

// ── Conviction engine ─────────────────────────────────────────

const PARAMS = {
  SCORE_MAX_VOLUME:     22,
  SCORE_MAX_INSIDER:    22,
  SCORE_MAX_SENTIMENT:  12,
  SCORE_MAX_TECHNICAL:  14,
  SCORE_MAX_OPTIONS:     8,
  SCORE_MAX_MACRO:      12,
  SCORE_MAX_KALMAN:     10,
  CONVICTION_GATE:      45,
  CONVICTION_HIGH:      65,
  CONVICTION_ELITE:     82,
  KF_Q:                0.001,
  KF_R:                0.25,
  HZ_BREAKOUT:         0.18,
  HZ_ACCUM:            0.02,
  HZ_MOM:              0.08,
  ENT_DOMINANT:        0.40,
  ENT_DIFFUSE:         2.20,
};

const HAZARD_RATES = {
  BREAKOUT: () => PARAMS.HZ_BREAKOUT,
  ACCUMULATION: () => PARAMS.HZ_ACCUM,
  MOMENTUM_CONTINUATION: () => PARAMS.HZ_MOM,
  OVERSOLD_BOUNCE: () => 0.15,
  OPTIONS_SWEEP: () => 0.30,
  CATALYST: () => 0.10,
  UNKNOWN: () => 0.10,
};

const BAYES_PARAMS = {
  volume:    { yes: [0.75, 0.20], no: [0.25, 0.25] },
  insider:   { yes: [0.80, 0.18], no: [0.15, 0.20] },
  sentiment: { yes: [0.60, 0.25], no: [0.30, 0.28] },
  technical: { yes: [0.65, 0.22], no: [0.35, 0.28] },
  options:   { yes: [0.75, 0.20], no: [0.20, 0.22] },
  macro:     { yes: [0.58, 0.25], no: [0.40, 0.28] },
  kalman:    { yes: [0.70, 0.22], no: [0.30, 0.25] },
};

function clamp(v, lo, hi) { return Math.max(lo, Math.min(hi, v)); }

function _scoreVolume(volRatio, dollarVol) {
  let score = 0;
  if (volRatio > 8) score += 22;
  else if (volRatio > 5) score += 17;
  else if (volRatio > 3) score += 12;
  else if (volRatio > 2) score += 7;
  else if (volRatio > 1.5) score += 3;
  // dollar vol liquidity boost
  if (dollarVol > 10) score += 2;
  else if (dollarVol < 2) score -= 3;
  return clamp(score, 0, PARAMS.SCORE_MAX_VOLUME);
}

function _scoreInsider(insiderDollar, insiderDays) {
  if (insiderDollar <= 0) return 0;
  let score = 0;
  if (insiderDollar >= 2000000) score += 22;
  else if (insiderDollar >= 500000) score += 17;
  else if (insiderDollar >= 100000) score += 12;
  else if (insiderDollar >= 25000) score += 7;
  else score += 3;
  // recency discount (days since filing)
  if (insiderDays > 45) score -= 6;
  else if (insiderDays > 21) score -= 3;
  return clamp(score, 0, PARAMS.SCORE_MAX_INSIDER);
}

function _scoreSentiment(sentScore) {
  // sentScore ∈ [-1, 1]
  let score = 0;
  if (sentScore > 0.7) score = 12;
  else if (sentScore > 0.4) score = 9;
  else if (sentScore > 0.1) score = 5;
  else if (sentScore > -0.1) score = 2;
  else if (sentScore < -0.4) score = -2;
  return clamp(score, 0, PARAMS.SCORE_MAX_SENTIMENT);
}

function _scoreTechnical(above50ma, priceChg5d, atrPct) {
  let score = 0;
  if (above50ma) { score += 5; }
  if (priceChg5d > 8) score += 9;
  else if (priceChg5d > 4) score += 6;
  else if (priceChg5d > 1) score += 3;
  else if (priceChg5d < -5) score -= 3;
  // ATR: higher ATR = more opportunity
  if (atrPct > 4) score += 2;
  else if (atrPct < 1) score -= 1;
  return clamp(score, 0, PARAMS.SCORE_MAX_TECHNICAL);
}

function _scoreOptions(cpRatio, optionsFlow) {
  let score = 0;
  score += clamp(optionsFlow, 0, 8); // direct score
  if (cpRatio > 2) score += 2;  // bullish call skew
  else if (cpRatio < 0.8) score -= 2;
  return clamp(score, 0, PARAMS.SCORE_MAX_OPTIONS);
}

function _classifySetup(volRatio, insiderDollar, above50ma, priceChg5d, cpRatio) {
  if (insiderDollar >= 100000 && priceChg5d < 5) return 'ACCUMULATION';
  if (volRatio > 3 && priceChg5d > 3 && above50ma) return 'BREAKOUT';
  if (cpRatio > 2 && optionsFlow() > 4) return 'OPTIONS_SWEEP';
  if (priceChg5d > 6 && volRatio > 2) return 'MOMENTUM_CONTINUATION';
  if (priceChg5d < -5 && volRatio > 2) return 'OVERSOLD_BOUNCE';
  return 'UNKNOWN';
}

function optionsFlow() { return parseFloat(document.getElementById('optionsFlow').value); }

function _scoreKalman(velocityZ, confidence) {
  let score = 0;
  if (velocityZ > 2.5) score = 10;
  else if (velocityZ > 2.0) score = 8;
  else if (velocityZ > 1.5) score = 6;
  else if (velocityZ > 1.0) score = 5;
  else if (velocityZ > 0.5) score = 3;
  else if (velocityZ > 0.0) score = 2;
  else if (velocityZ < -2.0) score = -6;
  else if (velocityZ < -1.5) score = -4;
  else if (velocityZ < -1.0) score = -2;
  if (score !== 0) {
    if (confidence > 0.75) score = Math.round(score * 1.30);
    else if (confidence < 0.45) score = Math.round(score * 0.50);
  }
  return clamp(score, -6, PARAMS.SCORE_MAX_KALMAN);
}

function _signalEntropy(rawVolume, rawInsider, rawSentiment, rawTechnical, rawOptions, rawKalman) {
  const D = 6;
  const H_MAX = Math.log2(D);
  const fracs = [
    Math.max(0, rawVolume) / PARAMS.SCORE_MAX_VOLUME,
    Math.max(0, rawInsider) / PARAMS.SCORE_MAX_INSIDER,
    Math.max(0, rawSentiment) / PARAMS.SCORE_MAX_SENTIMENT,
    Math.max(0, rawTechnical) / PARAMS.SCORE_MAX_TECHNICAL,
    Math.max(0, rawOptions) / PARAMS.SCORE_MAX_OPTIONS,
    Math.max(0, rawKalman) / PARAMS.SCORE_MAX_KALMAN,
  ];
  const total = fracs.reduce((a,b) => a+b, 0);
  if (total <= 0) return { H: H_MAX, probs: fracs, interp: 'no_signal', dominant: null };
  const probs = fracs.map(v => v / total);
  let H = 0;
  for (const p of probs) if (p > 0) H -= p * Math.log2(p);

  const names = ['VOLUME','INSIDER','SENTIMENT','TECHNICAL','OPTIONS','KALMAN'];
  const maxIdx = probs.indexOf(Math.max(...probs));

  let interp;
  if (H <= PARAMS.ENT_DOMINANT) interp = 'DOMINANT';
  else if (H <= 1.3) interp = 'CONCENTRATED';
  else if (H <= 1.8) interp = 'MIXED';
  else if (H <= PARAMS.ENT_DIFFUSE) interp = 'DIFFUSE';
  else interp = 'MAX DIFFUSION';

  return { H, probs, interp, dominant: names[maxIdx], H_MAX };
}

function _scoreEntropy(H) {
  if (H <= PARAMS.ENT_DOMINANT) return 10;
  if (H <= 0.8) return 7;
  if (H <= 1.3) return 4;
  if (H <= 1.8) return 1;
  if (H <= PARAMS.ENT_DIFFUSE) return -2;
  return -6;
}

function _gaussianLogPDF(x, mu, sigma) {
  const z = (x - mu) / sigma;
  return -0.5 * z * z - Math.log(sigma);
}

function _computeBayesian(rawVol, rawIns, rawSent, rawTech, rawOpts, rawMacro, rawKalman) {
  const fracs = {
    volume:    clamp(rawVol / PARAMS.SCORE_MAX_VOLUME, 0, 1),
    insider:   clamp(rawIns / PARAMS.SCORE_MAX_INSIDER, 0, 1),
    sentiment: clamp(rawSent / PARAMS.SCORE_MAX_SENTIMENT, 0, 1),
    technical: clamp(rawTech / PARAMS.SCORE_MAX_TECHNICAL, 0, 1),
    options:   clamp(rawOpts / PARAMS.SCORE_MAX_OPTIONS, 0, 1),
    macro:     clamp(rawMacro / PARAMS.SCORE_MAX_MACRO, 0, 1),
    kalman:    clamp(rawKalman / PARAMS.SCORE_MAX_KALMAN, 0, 1),
  };
  let logOdds = 0;
  for (const [dim, frac] of Object.entries(fracs)) {
    const p = BAYES_PARAMS[dim]; if (!p) continue;
    logOdds += _gaussianLogPDF(frac, p.yes[0], p.yes[1]) - _gaussianLogPDF(frac, p.no[0], p.no[1]);
  }
  const posterior = 1 / (1 + Math.exp(-logOdds));
  let bonus = 0;
  if (posterior > 0.80) bonus = 8;
  else if (posterior > 0.65) bonus = 4;
  else if (posterior < 0.30) bonus = -6;
  else if (posterior < 0.45) bonus = -3;
  return { posterior, bonus };
}

function _computeSurvival(ageHours, setupType) {
  const lambdaFn = HAZARD_RATES[setupType] || HAZARD_RATES.UNKNOWN;
  const lambda = lambdaFn();
  const survival = Math.exp(-lambda * Math.max(0, ageHours));
  const halfLife = Math.LN2 / lambda;
  return { survival, halfLife, lambda, isStale: survival < 0.30 };
}

function _survivalPenalty(survival, ageHours, rawVol, rawOpts) {
  const baseRaw = Math.max(0, rawVol + rawOpts);
  const base = -Math.min(20, Math.round(baseRaw * (1 - survival) * 0.35));
  const volFresh = Math.exp(-0.40 * ageHours);
  const optFresh = Math.exp(-0.35 * ageHours);
  const volP = rawVol > 0 ? -Math.round(rawVol * (1 - volFresh) * 0.5) : 0;
  const optP = rawOpts > 0 ? -Math.round(rawOpts * (1 - optFresh) * 0.5) : 0;
  return Math.max(-25, base + volP + optP);
}

// ── Traps ──────────────────────────────────────────────────────
function _computeTraps(volRatio, priceChg5d, insiderDollar, cpRatio, inPortfolio, sectorTrap, marketCap, dollarVol) {
  const flags = [];
  if (inPortfolio) flags.push('IN_PORTFOLIO');
  if (sectorTrap) flags.push('SECTOR_FLAG');
  if (dollarVol < 0.5) flags.push('HIGH_LIQ_RISK');
  else if (dollarVol < 2) flags.push('MODERATE_LIQ_RISK');
  if (volRatio > 5 && priceChg5d > 12) flags.push('POSSIBLE_PUMP');
  if (cpRatio < 0.5 && volRatio > 3) flags.push('BEARISH_OPTIONS');
  if (priceChg5d > 20) flags.push('EXTENDED_MOVE');
  return flags;
}

// ── Main compute ───────────────────────────────────────────────
function computeConviction() {
  syncParams();

  // Read inputs
  const volRatio     = +document.getElementById('volRatio').value;
  const dollarVol    = +document.getElementById('dollarVol').value;
  const signalAge    = +document.getElementById('signalAge').value;
  const insiderDollar= +document.getElementById('insiderDollar').value;
  const insiderDays  = +document.getElementById('insiderDays').value;
  const sentScore    = +document.getElementById('sentiment').value;
  const macroScoreRaw= +document.getElementById('macroScore').value;
  const above50ma    = +document.getElementById('above50ma').value === 1;
  const priceChg5d   = +document.getElementById('priceChg5d').value;
  const atrPct       = +document.getElementById('atrPct').value;
  const cpRatio      = +document.getElementById('cpRatio').value;
  const optFlow      = +document.getElementById('optionsFlow').value;
  const kalmanVZ     = +document.getElementById('kalmanVZ').value;
  const kalmanConf   = +document.getElementById('kalmanConf').value;
  const marketCap    = +document.getElementById('marketCap').value;
  const inPortfolio  = +document.getElementById('inPortfolio').value === 1;
  const instFlow     = +document.getElementById('instFlow').value;
  const sectorBonus  = +document.getElementById('sectorBonus').value;
  const sectorTrap   = +document.getElementById('sectorTrap').value === 1;

  // Raw scores
  const rawVolume    = _scoreVolume(volRatio, dollarVol);
  const rawInsider   = _scoreInsider(insiderDollar, insiderDays);
  const rawSentiment = _scoreSentiment(sentScore);
  const rawTechnical = _scoreTechnical(above50ma, priceChg5d, atrPct);
  const rawOptions   = _scoreOptions(cpRatio, optFlow);
  const rawKalman    = _scoreKalman(kalmanVZ, kalmanConf);

  // Entropy
  const entropy = _signalEntropy(rawVolume, rawInsider, rawSentiment, rawTechnical, rawOptions, rawKalman);
  const entropyScore = _scoreEntropy(entropy.H);

  // Convergence: count how many dims are above 50% of their max
  const dims = [rawVolume/PARAMS.SCORE_MAX_VOLUME, rawInsider/PARAMS.SCORE_MAX_INSIDER,
                rawSentiment/PARAMS.SCORE_MAX_SENTIMENT, rawTechnical/PARAMS.SCORE_MAX_TECHNICAL,
                rawOptions/PARAMS.SCORE_MAX_OPTIONS, rawKalman/PARAMS.SCORE_MAX_KALMAN];
  const above50count = dims.filter(d => d > 0.5).length;
  const convergenceScore = above50count >= 4 ? 10 : above50count >= 3 ? 7 : above50count >= 2 ? 4 : above50count >= 1 ? 1 : 0;

  // Bayesian
  const bayes = _computeBayesian(rawVolume, rawInsider, rawSentiment, rawTechnical, rawOptions, macroScoreRaw, rawKalman);

  // Setup type
  const setupType = _classifySetup(volRatio, insiderDollar, above50ma, priceChg5d, cpRatio);

  // Survival
  const surv = _computeSurvival(signalAge, setupType);
  const survPenalty = _survivalPenalty(surv.survival, signalAge, rawVolume, rawOptions);

  // Liquidity penalty
  const liqPenalty = dollarVol < 0.5 ? -20 : dollarVol < 2 ? -10 : dollarVol < 10 ? -4 : 0;

  // Base total
  const baseTotal = Math.max(0, rawVolume + rawInsider + rawSentiment + macroScoreRaw + convergenceScore + rawTechnical + rawOptions + rawKalman + entropyScore);
  let total = Math.min(100, Math.max(0, baseTotal + bayes.bonus + survPenalty + liqPenalty + instFlow + sectorBonus));

  // Traps
  const trapFlags = _computeTraps(volRatio, priceChg5d, insiderDollar, cpRatio, inPortfolio, sectorTrap, marketCap, dollarVol);
  const hasTrap = trapFlags.length > 0;

  // Action
  let action;
  if (inPortfolio) action = 'HOLD';
  else if (hasTrap && trapFlags.some(f => ['SECTOR_FLAG','HIGH_LIQ_RISK'].includes(f))) action = 'WATCH';
  else if (total < PARAMS.CONVICTION_GATE) action = 'BELOW GATE';
  else if (total >= PARAMS.CONVICTION_HIGH) action = 'BUY';
  else action = 'WATCH';

  // Tier
  const tier = total >= PARAMS.CONVICTION_ELITE ? 'ELITE' : total >= PARAMS.CONVICTION_HIGH ? 'HIGH' : total >= PARAMS.CONVICTION_GATE ? 'MEDIUM' : 'BELOW GATE';

  return {
    total: Math.round(total),
    action, tier, setupType, trapFlags,
    breakdown: {
      volume:      rawVolume,
      insider:     rawInsider,
      sentiment:   rawSentiment,
      technical:   rawTechnical,
      options:     rawOptions,
      macro:       macroScoreRaw,
      convergence: convergenceScore,
      kalman:      rawKalman,
      entropy:     entropyScore,
      bayes:       bayes.bonus,
      survPenalty, liqPenalty, instFlow, sectorBonus,
    },
    entropy, bayes, surv, survPenalty,
    rawKalman, kalmanVZ, kalmanConf,
    signalAge,
  };
}

// ── Sync param sliders display ──────────────────────────────────
function syncParams() {
  PARAMS.SCORE_MAX_VOLUME    = +document.getElementById('pmVolume').value;
  PARAMS.SCORE_MAX_INSIDER   = +document.getElementById('pmInsider').value;
  PARAMS.SCORE_MAX_SENTIMENT = +document.getElementById('pmSentiment').value;
  PARAMS.SCORE_MAX_TECHNICAL = +document.getElementById('pmTechnical').value;
