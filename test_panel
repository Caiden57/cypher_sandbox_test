}

// ── Mode ─────────────────────────────────────────────────────────
function setMode(m) {
  document.querySelectorAll('.mode-tab').forEach((t,i) => {
    t.classList.toggle('active', ['single','sweep','compare'][i] === m);
  });
}

// ── Main compute loop ──────────────────────────────────────────
function compute() {
  syncInputLabels();
  syncParams();
  const result = computeConviction();
  renderOutput(result);
}

