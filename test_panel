<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>CYPHER · SCANNER SANDBOX</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@300;400;500;600;700&family=Syne:wght@400;500;600;700;800&display=swap');

*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --bg:       #080a0d;
  --bg1:      #0d1117;
  --bg2:      #111820;
  --bg3:      #182030;
  --border:   rgba(255,255,255,0.07);
  --border2:  rgba(255,255,255,0.12);
  --text1:    #f0f4ff;
  --text2:    #8b9cb8;
  --text3:    #4a5568;
  --accent:   #3d7fff;
  --gain:     #19d48a;
  --loss:     #ff4d6a;
  --warn:     #f5a623;
  --purple:   #a78bfa;
  --teal:     #2dd4bf;
  --gold:     #fbbf24;
  --mono:     'JetBrains Mono', monospace;
  --sans:     'Syne', sans-serif;
}

html, body { height: 100%; background: var(--bg); color: var(--text1); font-family: var(--mono); overflow: hidden; }

/* ── Layout ── */
.app { display: grid; grid-template-columns: 320px 1fr 280px; grid-template-rows: 52px 1fr 180px; height: 100vh; gap: 0; }
.header { grid-column: 1 / -1; display: flex; align-items: center; justify-content: space-between; padding: 0 20px; border-bottom: 1px solid var(--border); background: var(--bg1); }
.panel-left  { grid-row: 2; border-right: 1px solid var(--border); overflow-y: auto; background: var(--bg1); }
.panel-center { grid-row: 2; overflow-y: auto; background: var(--bg); }
.panel-right  { grid-row: 2; border-left: 1px solid var(--border); overflow-y: auto; background: var(--bg1); }
.panel-bottom { grid-column: 1 / -1; border-top: 1px solid var(--border); background: var(--bg1); overflow-x: auto; overflow-y: hidden; display: flex; align-items: stretch; }

/* ── Scrollbar ── */
::-webkit-scrollbar { width: 4px; height: 4px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--border2); border-radius: 2px; }

/* ── Header ── */
.logo { font-family: var(--sans); font-size: 13px; font-weight: 800; letter-spacing: .2em; color: var(--text1); }
.logo span { color: var(--accent); }
.header-center { font-size: 10px; color: var(--text3); letter-spacing: .12em; }
.run-btn {
  font-family: var(--mono); font-size: 10px; font-weight: 600; letter-spacing: .1em;
  padding: 6px 16px; background: var(--accent); color: #fff; border: none;
  border-radius: 4px; cursor: pointer; transition: opacity .15s;
}
.run-btn:hover { opacity: .85; }

/* ── Panel headers ── */
.ph { padding: 12px 16px 8px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
.ph-label { font-size: 9px; font-weight: 600; letter-spacing: .15em; color: var(--text3); }
.ph-action { font-size: 9px; color: var(--accent); cursor: pointer; }
.ph-action:hover { opacity: .7; }

/* ── Section groups ── */
.section { padding: 12px 16px; border-bottom: 1px solid var(--border); }
.section-label { font-size: 8px; font-weight: 700; letter-spacing: .15em; color: var(--text3); margin-bottom: 10px; text-transform: uppercase; }

/* ── Signal inputs ── */
.sig-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.sig-name { font-size: 9px; color: var(--text2); width: 80px; flex-shrink: 0; }
.sig-range { flex: 1; height: 3px; accent-color: var(--accent); cursor: pointer; }
.sig-val { font-size: 10px; font-weight: 600; color: var(--text1); width: 52px; text-align: right; font-family: var(--mono); }
.sig-unit { font-size: 8px; color: var(--text3); width: 28px; }

/* ── Presets ── */
.presets { display: flex; gap: 6px; flex-wrap: wrap; padding: 10px 16px; border-bottom: 1px solid var(--border); }
.preset-btn { font-size: 8px; font-weight: 600; letter-spacing: .08em; padding: 4px 8px; border: 1px solid var(--border2); border-radius: 3px; background: transparent; color: var(--text2); cursor: pointer; transition: all .12s; white-space: nowrap; }
.preset-btn:hover { border-color: var(--accent); color: var(--accent); }

/* ── Ticker selector ── */
.ticker-input { font-family: var(--mono); font-size: 16px; font-weight: 700; background: var(--bg2); border: 1px solid var(--border2); color: var(--text1); padding: 6px 10px; border-radius: 4px; width: 90px; text-transform: uppercase; letter-spacing: .08em; }
.ticker-input:focus { outline: none; border-color: var(--accent); }

/* ── Center — conviction display ── */
.conviction-main { padding: 24px 28px; }
.conv-score-big { font-size: 72px; font-weight: 700; font-family: var(--sans); line-height: 1; letter-spacing: -.03em; transition: all .2s; }
.conv-score-big.high  { color: var(--gain); }
.conv-score-big.med   { color: var(--warn); }
.conv-score-big.low   { color: var(--text2); }
.conv-action { font-size: 11px; font-weight: 600; letter-spacing: .18em; margin-top: 4px; }
.action-buy   { color: var(--gain); }
.action-watch { color: var(--warn); }
.action-hold  { color: var(--text2); }

.conv-meta { display: flex; gap: 16px; margin-top: 12px; }
.conv-meta-item { display: flex; flex-direction: column; gap: 2px; }
.conv-meta-label { font-size: 8px; color: var(--text3); letter-spacing: .1em; }
.conv-meta-val { font-size: 11px; font-weight: 600; color: var(--text1); }

/* ── Waterfall chart ── */
.waterfall { padding: 0 28px 20px; }
.wf-label { font-size: 9px; font-weight: 700; letter-spacing: .12em; color: var(--text3); margin-bottom: 14px; }
.wf-row { display: flex; align-items: center; gap: 10px; margin-bottom: 6px; }
.wf-name { font-size: 9px; color: var(--text2); width: 100px; flex-shrink: 0; text-align: right; }
.wf-bar-wrap { flex: 1; height: 14px; background: var(--bg2); border-radius: 2px; overflow: hidden; position: relative; }
.wf-bar { height: 100%; border-radius: 2px; transition: width .25s ease; min-width: 2px; }
.wf-score { font-size: 9px; font-weight: 600; width: 32px; text-align: right; }
.wf-max { font-size: 8px; color: var(--text3); width: 28px; }

/* ── Survival / coherence ── */
.physics-block { padding: 16px 28px; border-top: 1px solid var(--border); }
.physics-row { display: flex; justify-content: space-between; margin-bottom: 6px; }
.physics-key { font-size: 9px; color: var(--text3); }
.physics-val { font-size: 9px; font-weight: 600; color: var(--text1); font-family: var(--mono); }

/* ── Trap flags ── */
.traps { padding: 12px 28px; }
.trap-badge { display: inline-block; font-size: 8px; font-weight: 700; letter-spacing: .08em; padding: 3px 7px; border-radius: 2px; background: rgba(255,77,106,0.15); color: var(--loss); border: 1px solid rgba(255,77,106,0.3); margin: 2px; }

/* ── Right panel — tuning ── */
.tune-row { display: flex; align-items: center; gap: 8px; margin-bottom: 8px; }
.tune-name { font-size: 9px; color: var(--text2); width: 120px; flex-shrink: 0; }
.tune-range { flex: 1; height: 3px; accent-color: var(--purple); cursor: pointer; }
.tune-val { font-size: 9px; font-weight: 600; color: var(--purple); width: 36px; text-align: right; }
.reset-btn { font-size: 8px; padding: 2px 6px; border: 1px solid var(--border); border-radius: 3px; background: none; color: var(--text3); cursor: pointer; }
.reset-btn:hover { color: var(--text1); border-color: var(--border2); }

/* ── Bottom — scenario history ── */
.scenario-list { display: flex; gap: 1px; align-items: stretch; padding: 0; }
.scenario-card { width: 160px; flex-shrink: 0; padding: 10px 12px; cursor: pointer; border-right: 1px solid var(--border); transition: background .12s; display: flex; flex-direction: column; justify-content: space-between; }
.scenario-card:hover { background: var(--bg2); }
.scenario-card.active { background: var(--bg3); border-top: 2px solid var(--accent); }
.sc-ticker { font-size: 12px; font-weight: 700; font-family: var(--sans); color: var(--text1); }
.sc-score { font-size: 20px; font-weight: 700; font-family: var(--sans); }
.sc-meta { font-size: 8px; color: var(--text3); margin-top: 2px; }
.sc-delta { font-size: 8px; font-weight: 600; }
.sc-delta.pos { color: var(--gain); }
.sc-delta.neg { color: var(--loss); }
.sc-label { font-size: 8px; font-weight: 600; letter-spacing: .08em; }
.add-scenario { width: 48px; display: flex; align-items: center; justify-content: center; cursor: pointer; color: var(--text3); font-size: 20px; flex-shrink: 0; }
.add-scenario:hover { color: var(--accent); }

/* ── Bayesian params ── */
.bayes-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 4px 12px; }
.bayes-item { display: flex; flex-direction: column; gap: 2px; }
.bayes-item label { font-size: 8px; color: var(--text3); }
.bayes-item input { font-family: var(--mono); font-size: 9px; background: var(--bg2); border: 1px solid var(--border); color: var(--text1); padding: 3px 5px; border-radius: 2px; width: 100%; }
.bayes-item input:focus { outline: none; border-color: var(--purple); }

/* ── Mode toggle ── */
.mode-tabs { display: flex; gap: 1px; background: var(--bg2); border-radius: 4px; padding: 2px; }
.mode-tab { font-size: 8px; font-weight: 600; letter-spacing: .08em; padding: 4px 10px; border-radius: 3px; cursor: pointer; color: var(--text3); }
.mode-tab.active { background: var(--bg3); color: var(--text1); }

/* ── Gauge ring ── */
.gauge-wrap { position: relative; width: 56px; height: 56px; flex-shrink: 0; }
.gauge-wrap svg { transform: rotate(-90deg); }
.gauge-label { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700; }

.animate-in { animation: fadeUp .2s ease both; }
@keyframes fadeUp { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
</style>
</head>
<body>

<div class="app">

  <!-- Header -->
  <header class="header">
    <div class="logo">CYPHER <span>·</span> SCANNER SANDBOX</div>
    <div class="header-center">CONVICTION ENGINE SIMULATOR — NO LIVE DATA</div>
    <div style="display:flex;align-items:center;gap:10px;">
      <div class="mode-tabs" id="modeTabs">
        <div class="mode-tab active" onclick="setMode('single')">SINGLE</div>
        <div class="mode-tab" onclick="setMode('sweep')">PARAM SWEEP</div>
        <div class="mode-tab" onclick="setMode('compare')">COMPARE</div>
      </div>
      <button class="run-btn" onclick="runAndSave()">RUN + SAVE ▶</button>
    </div>
  </header>

  <!-- Left: Signal Inputs -->
  <div class="panel-left">
    <div class="ph">
      <span class="ph-label">SIGNAL INPUTS</span>
      <span class="ph-action" onclick="randomize()">RANDOMIZE</span>
    </div>

    <div class="section" style="padding-top:14px;padding-bottom:10px;">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
        <input class="ticker-input" id="tickerInput" value="CRDO" maxlength="5" oninput="this.value=this.value.toUpperCase();compute()">
        <div>
          <div class="conv-meta-label">SECTOR</div>
          <select id="sectorSel" onchange="compute()" style="font-family:var(--mono);font-size:9px;background:var(--bg2);border:1px solid var(--border);color:var(--text1);padding:4px 6px;border-radius:3px;margin-top:2px;cursor:pointer;">
            <option value="SEMICONDUCTORS">Semis</option>
            <option value="ENERGY_EP">E&amp;P</option>
            <option value="ENERGY_REFINER">Refiner</option>
            <option value="BANKS_REGIONAL">Reg. Bank</option>
            <option value="BANKS_MONEY_CENTER">Money Center</option>
            <option value="BIOTECH">Biotech</option>
            <option value="DEFENSE">Defense</option>
            <option value="AIRLINES">Airlines</option>
            <option value="INSURANCE">Insurance</option>
            <option value="CONSUMER_DISCRETIONARY">Consumer</option>
            <option value="HOMEBUILDERS">Homebuilders</option>
            <option value="SHIPPING">Shipping</option>
            <option value="AGRICULTURE">Agriculture</option>
            <option value="PHARMA">Pharma</option>
            <option value="">Unknown</option>
          </select>
        </div>
      </div>
    </div>

    <!-- Presets -->
    <div class="presets">
      <span style="font-size:8px;color:var(--text3);letter-spacing:.1em;align-self:center;">PRESETS</span>
      <button class="preset-btn" onclick="loadPreset('strongInsider')">Strong Insider</button>
      <button class="preset-btn" onclick="loadPreset('volumeBreakout')">Vol Breakout</button>
      <button class="preset-btn" onclick="loadPreset('biotech')">PDUFA Play</button>
      <button class="preset-btn" onclick="loadPreset('defense')">Defense Contract</button>
      <button class="preset-btn" onclick="loadPreset('weakAll')">Weak All</button>
      <button class="preset-btn" onclick="loadPreset('trapSetup')">Trap Setup</button>
    </div>

    <!-- Volume -->
    <div class="section">
      <div class="section-label">Volume Signals</div>
      <div class="sig-row">
        <span class="sig-name">Vol Ratio</span>
        <input class="sig-range" type="range" id="volRatio" min="0" max="10" step="0.1" value="3.2" oninput="compute()">
        <span class="sig-val" id="volRatioV">3.2</span><span class="sig-unit">×avg</span>
      </div>
      <div class="sig-row">
        <span class="sig-name">Dollar Vol</span>
        <input class="sig-range" type="range" id="dollarVol" min="0" max="50" step="0.5" value="12" oninput="compute()">
        <span class="sig-val" id="dollarVolV">$12M</span><span class="sig-unit">/day</span>
      </div>
      <div class="sig-row">
        <span class="sig-name">Signal Age</span>
        <input class="sig-range" type="range" id="signalAge" min="0" max="72" step="0.5" value="2" oninput="compute()">
        <span class="sig-val" id="signalAgeV">2.0</span><span class="sig-unit">hrs</span>
      </div>
    </div>

    <!-- Insider -->
    <div class="section">
      <div class="section-label">Insider Activity</div>
      <div class="sig-row">
        <span class="sig-name">Insider $</span>
        <input class="sig-range" type="range" id="insiderDollar" min="0" max="5000000" step="10000" value="0" oninput="compute()">
        <span class="sig-val" id="insiderDollarV">$0</span><span class="sig-unit"></span>
      </div>
      <div class="sig-row">
        <span class="sig-name">Days Since</span>
        <input class="sig-range" type="range" id="insiderDays" min="0" max="60" step="1" value="0" oninput="compute()">
        <span class="sig-val" id="insiderDaysV">0</span><span class="sig-unit">days</span>
      </div>
    </div>

    <!-- Sentiment -->
    <div class="section">
      <div class="section-label">Sentiment &amp; Macro</div>
      <div class="sig-row">
        <span class="sig-name">Sentiment</span>
        <input class="sig-range" type="range" id="sentiment" min="-1" max="1" step="0.05" value="0.4" oninput="compute()">
        <span class="sig-val" id="sentimentV">+0.40</span><span class="sig-unit"></span>
      </div>
      <div class="sig-row">
        <span class="sig-name">Macro Score</span>
        <input class="sig-range" type="range" id="macroScore" min="0" max="12" step="0.5" value="6" oninput="compute()">
        <span class="sig-val" id="macroScoreV">6.0</span><span class="sig-unit">/12</span>
      </div>
    </div>

    <!-- Technical -->
    <div class="section">
      <div class="section-label">Technical &amp; Options</div>
      <div class="sig-row">
        <span class="sig-name">Above 50MA</span>
        <input class="sig-range" type="range" id="above50ma" min="0" max="1" step="1" value="1" oninput="compute()">
        <span class="sig-val" id="above50maV">YES</span><span class="sig-unit"></span>
      </div>
      <div class="sig-row">
        <span class="sig-name">Price Chg 5d</span>
        <input class="sig-range" type="range" id="priceChg5d" min="-15" max="25" step="0.5" value="4.2" oninput="compute()">
        <span class="sig-val" id="priceChg5dV">+4.2</span><span class="sig-unit">%</span>
      </div>
      <div class="sig-row">
        <span class="sig-name">ATR %</span>
        <input class="sig-range" type="range" id="atrPct" min="0.5" max="8" step="0.1" value="2.1" oninput="compute()">
        <span class="sig-val" id="atrPctV">2.1</span><span class="sig-unit">%</span>
      </div>
      <div class="sig-row">
        <span class="sig-name">C/P Ratio</span>
        <input class="sig-range" type="range" id="cpRatio" min="0" max="5" step="0.1" value="1.8" oninput="compute()">
        <span class="sig-val" id="cpRatioV">1.8</span><span class="sig-unit"></span>
      </div>
      <div class="sig-row">
        <span class="sig-name">Options Flow</span>
        <input class="sig-range" type="range" id="optionsFlow" min="0" max="8" step="0.5" value="4" oninput="compute()">
        <span class="sig-val" id="optionsFlowV">4.0</span><span class="sig-unit">/8</span>
      </div>
    </div>

    <!-- Kalman -->
    <div class="section">
      <div class="section-label">Kalman Trend State</div>
      <div class="sig-row">
        <span class="sig-name">Velocity Z</span>
        <input class="sig-range" type="range" id="kalmanVZ" min="-3" max="3" step="0.05" value="1.4" oninput="compute()">
        <span class="sig-val" id="kalmanVZV">+1.40</span><span class="sig-unit">σ</span>
      </div>
      <div class="sig-row">
        <span class="sig-name">Confidence</span>
        <input class="sig-range" type="range" id="kalmanConf" min="0" max="1" step="0.01" value="0.72" oninput="compute()">
        <span class="sig-val" id="kalmanConfV">72</span><span class="sig-unit">%</span>
      </div>
    </div>

    <!-- Market data -->
    <div class="section">
      <div class="section-label">Company Profile</div>
      <div class="sig-row">
        <span class="sig-name">Market Cap</span>
        <input class="sig-range" type="range" id="marketCap" min="50" max="5000" step="50" value="2100" oninput="compute()">
        <span class="sig-val" id="marketCapV">$2.1B</span><span class="sig-unit"></span>
      </div>
      <div class="sig-row">
        <span class="sig-name">In Portfolio</span>
        <input class="sig-range" type="range" id="inPortfolio" min="0" max="1" step="1" value="0" oninput="compute()">
        <span class="sig-val" id="inPortfolioV">NO</span><span class="sig-unit"></span>
      </div>
      <div class="sig-row">
        <span class="sig-name">13F Flow</span>
        <input class="sig-range" type="range" id="instFlow" min="-15" max="12" step="1" value="0" oninput="compute()">
        <span class="sig-val" id="instFlowV">0</span><span class="sig-unit">pts</span>
      </div>
    </div>

    <!-- Sector intel -->
    <div class="section" style="padding-bottom:16px;">
      <div class="section-label">Sector Intelligence</div>
      <div class="sig-row">
        <span class="sig-name">Sector Bonus</span>
        <input class="sig-range" type="range" id="sectorBonus" min="-20" max="30" step="1" value="0" oninput="compute()">
        <span class="sig-val" id="sectorBonusV">0</span><span class="sig-unit">pts</span>
      </div>
      <div class="sig-row">
        <span class="sig-name">Sector Trap</span>
        <input class="sig-range" type="range" id="sectorTrap" min="0" max="1" step="1" value="0" oninput="compute()">
        <span class="sig-val" id="sectorTrapV">NONE</span><span class="sig-unit"></span>
      </div>
    </div>
  </div>

  <!-- Center: Output -->
  <div class="panel-center">
    <div class="conviction-main">
      <div style="display:flex;align-items:flex-start;gap:24px;">
        <div>
          <div class="conv-score-big" id="convScoreBig">—</div>
          <div class="conv-action" id="convAction">—</div>
        </div>
        <div style="margin-top:8px;">
          <div class="gauge-wrap">
            <svg width="56" height="56" viewBox="0 0 56 56">
              <circle cx="28" cy="28" r="22" fill="none" stroke="var(--bg2)" stroke-width="5"/>
              <circle id="gaugeRing" cx="28" cy="28" r="22" fill="none" stroke="var(--gain)" stroke-width="5"
                stroke-dasharray="138.2" stroke-dashoffset="138.2" stroke-linecap="round" style="transition:all .3s ease;"/>
            </svg>
            <div class="gauge-label" id="gaugeLabel" style="font-size:9px;color:var(--text2);">—</div>
          </div>
        </div>
        <div class="conv-meta" style="margin-top:8px;">
          <div class="conv-meta-item">
            <span class="conv-meta-label">TIER</span>
            <span class="conv-meta-val" id="metaTier">—</span>
          </div>
          <div class="conv-meta-item">
            <span class="conv-meta-label">SETUP</span>
            <span class="conv-meta-val" id="metaSetup">—</span>
          </div>
          <div class="conv-meta-item">
            <span class="conv-meta-label">SURVIVAL</span>
            <span class="conv-meta-val" id="metaSurvival">—</span>
          </div>
          <div class="conv-meta-item">
            <span class="conv-meta-label">BAYESIAN P</span>
            <span class="conv-meta-val" id="metaBayes">—</span>
          </div>
        </div>
      </div>
    </div>

    <!-- Waterfall -->
    <div class="waterfall">
      <div class="wf-label">CONVICTION BREAKDOWN</div>
      <div id="waterfall"></div>
    </div>

    <!-- Survival + Coherence -->
    <div class="physics-block">
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
        <div>
          <div class="wf-label" style="margin-bottom:8px;">SIGNAL SURVIVAL</div>
          <div class="physics-row"><span class="physics-key">Setup Type</span><span class="physics-val" id="phSetup">—</span></div>
          <div class="physics-row"><span class="physics-key">Hazard Rate λ</span><span class="physics-val" id="phLambda">—</span></div>
          <div class="physics-row"><span class="physics-key">Half-life</span><span class="physics-val" id="phHalflife">—</span></div>
          <div class="physics-row"><span class="physics-key">Signal Age</span><span class="physics-val" id="phAge">—</span></div>
