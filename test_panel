// ── Input label sync ────────────────────────────────────────────
function syncInputLabels() {
  const fmt = (id, fn) => {
    const el = document.getElementById(id);
    const vEl = document.getElementById(id+'V');
    if (!el || !vEl) return;
    vEl.textContent = fn(parseFloat(el.value));
  };
  fmt('volRatio',      v => v.toFixed(1));
  fmt('dollarVol',     v => '$' + v.toFixed(0) + 'M');
  fmt('signalAge',     v => v.toFixed(1));
  fmt('insiderDollar', v => v >= 1000000 ? '$' + (v/1000000).toFixed(1)+'M' : v >= 1000 ? '$'+(v/1000).toFixed(0)+'K' : '$'+v.toFixed(0));
  fmt('insiderDays',   v => v.toFixed(0));
  fmt('sentiment',     v => (v >= 0 ? '+' : '') + v.toFixed(2));
  fmt('macroScore',    v => v.toFixed(1));
  fmt('above50ma',     v => v ? 'YES' : 'NO');
  fmt('priceChg5d',    v => (v >= 0 ? '+' : '') + v.toFixed(1));
  fmt('atrPct',        v => v.toFixed(1));
  fmt('cpRatio',       v => v.toFixed(1));
  fmt('optionsFlow',   v => v.toFixed(1));
  fmt('kalmanVZ',      v => (v >= 0 ? '+' : '') + v.toFixed(2));
  fmt('kalmanConf',    v => (v*100).toFixed(0));
  fmt('marketCap',     v => v >= 1000 ? '$'+(v/1000).toFixed(1)+'B' : '$'+v.toFixed(0)+'M');
  fmt('inPortfolio',   v => v ? 'YES' : 'NO');
  fmt('instFlow',      v => (v >= 0 ? '+' : '') + v.toFixed(0));
  fmt('sectorBonus',   v => (v >= 0 ? '+' : '') + v.toFixed(0));
  fmt('sectorTrap',    v => v ? 'FLAGGED' : 'NONE');
}

// ── Render output ───────────────────────────────────────────────
const DIM_COLORS = {
  volume:      '#3d7fff',
  insider:     '#fbbf24',
  sentiment:   '#a78bfa',
  technical:   '#2dd4bf',
  options:     '#f97316',
  macro:       '#60a5fa',
  convergence: '#34d399',
  kalman:      '#e879f9',
  entropy:     '#fb923c',
  bayes:       '#4ade80',
  survPenalty: '#ff4d6a',
  liqPenalty:  '#ef4444',
  instFlow:    '#22d3ee',
  sectorBonus: '#a3e635',
};

const DIM_MAX = {
  volume: 22, insider: 22, sentiment: 12, technical: 14,
  options: 8, macro: 12, convergence: 10, kalman: 10,
  entropy: 10, bayes: 8, survPenalty: 0, liqPenalty: 0,
  instFlow: 12, sectorBonus: 30,
};

function renderOutput(result) {
  const { total, action, tier, setupType, trapFlags, breakdown, entropy, bayes, surv, survPenalty, rawKalman, kalmanVZ, kalmanConf, signalAge } = result;

  // Score
  const scoreEl = document.getElementById('convScoreBig');
  scoreEl.textContent = total;
  scoreEl.className = 'conv-score-big ' + (total >= 65 ? 'high' : total >= 45 ? 'med' : 'low');

  // Action
  const actionEl = document.getElementById('convAction');
  actionEl.textContent = action;
  actionEl.className = 'conv-action ' + (action === 'BUY' ? 'action-buy' : action === 'WATCH' ? 'action-watch' : 'action-hold');

  // Gauge
  const pct = total / 100;
  const circ = 138.2;
  document.getElementById('gaugeRing').style.strokeDashoffset = circ * (1 - pct);
  document.getElementById('gaugeRing').style.stroke = total >= 65 ? 'var(--gain)' : total >= 45 ? 'var(--warn)' : 'var(--text3)';
  document.getElementById('gaugeLabel').textContent = tier;

  // Meta
  document.getElementById('metaTier').textContent = tier;
  document.getElementById('metaSetup').textContent = setupType;
  document.getElementById('metaSurvival').textContent = (surv.survival * 100).toFixed(0) + '%';
  document.getElementById('metaBayes').textContent = (bayes.posterior * 100).toFixed(0) + '%';

  // Waterfall
  const wf = document.getElementById('waterfall');
  wf.innerHTML = '';
  const allDims = [
    ['Volume', breakdown.volume, PARAMS.SCORE_MAX_VOLUME],
    ['Insider', breakdown.insider, PARAMS.SCORE_MAX_INSIDER],
    ['Sentiment', breakdown.sentiment, PARAMS.SCORE_MAX_SENTIMENT],
    ['Technical', breakdown.technical, PARAMS.SCORE_MAX_TECHNICAL],
    ['Options', breakdown.options, PARAMS.SCORE_MAX_OPTIONS],
    ['Macro', breakdown.macro, PARAMS.SCORE_MAX_MACRO],
    ['Convergence', breakdown.convergence, 10],
    ['Kalman', breakdown.kalman, PARAMS.SCORE_MAX_KALMAN],
    ['Entropy', breakdown.entropy, 10],
    ['Bayesian', breakdown.bayes, 8],
    ['Survival', breakdown.survPenalty, 0],
    ['Liquidity', breakdown.liqPenalty, 0],
    ['Inst. Flow', breakdown.instFlow, 12],
    ['Sector', breakdown.sectorBonus, 30],
  ];

  for (const [name, score, max] of allDims) {
    const isNeg = score < 0;
    const absScore = Math.abs(score);
    const barPct = max > 0 ? (absScore / max) * 100 : Math.min(100, absScore * 5);
    const color = isNeg ? '#ff4d6a' : DIM_COLORS[name.toLowerCase().replace(/[^a-z]/g,'').replace('inst','instFlow').replace('flow','')] || 'var(--accent)';
    const scoreColor = isNeg ? '#ff4d6a' : score > 0 ? '#f0f4ff' : 'var(--text3)';
    const row = document.createElement('div');
    row.className = 'wf-row';
    row.innerHTML = `
      <span class="wf-name">${name}</span>
      <div class="wf-bar-wrap">
        <div class="wf-bar" style="width:${barPct}%;background:${color};opacity:${score === 0 ? 0.2 : 1}"></div>
      </div>
      <span class="wf-score" style="color:${scoreColor}">${score > 0 ? '+' : ''}${score}</span>
      <span class="wf-max">${max > 0 ? '/' + max : ''}</span>`;
    wf.appendChild(row);
  }

  // Survival
  document.getElementById('phSetup').textContent = setupType;
  document.getElementById('phLambda').textContent = surv.lambda.toFixed(3);
  document.getElementById('phHalflife').textContent = surv.halfLife.toFixed(1) + ' hrs';
  document.getElementById('phAge').textContent = signalAge.toFixed(1) + ' hrs';
  document.getElementById('phSurvival').textContent = (surv.survival * 100).toFixed(1) + '%' + (surv.isStale ? ' ⚠ STALE' : '');
  document.getElementById('phSurvival').style.color = surv.isStale ? 'var(--loss)' : 'var(--text1)';
  document.getElementById('phPenalty').textContent = survPenalty;
  document.getElementById('phPenalty').style.color = survPenalty < 0 ? 'var(--loss)' : 'var(--text3)';

  // Entropy
  document.getElementById('phEntropy').textContent = entropy.H.toFixed(4) + ' bits';
  document.getElementById('phEntropyRel').textContent = (entropy.H / entropy.H_MAX * 100).toFixed(0) + '% of max';
  document.getElementById('phDominant').textContent = entropy.dominant || '—';
  document.getElementById('phEntropyInterp').textContent = entropy.interp;
  document.getElementById('phEntropyScore').textContent = (breakdown.entropy > 0 ? '+' : '') + breakdown.entropy;
  document.getElementById('phEntropyScore').style.color = breakdown.entropy < 0 ? 'var(--loss)' : breakdown.entropy > 4 ? 'var(--gain)' : 'var(--text1)';

  // Traps
  const trapWrap = document.getElementById('trapWrap');
  const trapBadges = document.getElementById('trapBadges');
  trapBadges.innerHTML = '';
  if (trapFlags.length > 0) {
    trapWrap.style.display = 'block';
    trapFlags.forEach(f => {
      const b = document.createElement('span');
      b.className = 'trap-badge';
      b.textContent = f.replace(/_/g, ' ');
      trapBadges.appendChild(b);
    });
  } else {
    trapWrap.style.display = 'none';
  }
}

// ── Scenarios ───────────────────────────────────────────────────
let scenarios = [];
let activeScenarioIdx = -1;

function runAndSave() {
  syncInputLabels();
  const result = computeConviction();
  renderOutput(result);

  const ticker = document.getElementById('tickerInput').value || '???';
  const prev = scenarios.length > 0 ? scenarios[scenarios.length - 1].result.total : null;
  const delta = prev !== null ? result.total - prev : null;

  scenarios.push({ ticker, result, params: {...PARAMS}, ts: Date.now(), delta });
  activeScenarioIdx = scenarios.length - 1;
  renderScenarios();
}

function renderScenarios() {
  const list = document.getElementById('scenarioList');
  list.innerHTML = '';
  scenarios.forEach((sc, i) => {
    const el = document.createElement('div');
    el.className = 'scenario-card' + (i === activeScenarioIdx ? ' active' : '');
    const scoreColor = sc.result.total >= 65 ? 'var(--gain)' : sc.result.total >= 45 ? 'var(--warn)' : 'var(--text3)';
    const deltaHtml = sc.delta !== null ? `<span class="sc-delta ${sc.delta >= 0 ? 'pos' : 'neg'}">${sc.delta >= 0 ? '+' : ''}${sc.delta}</span>` : '';
    el.innerHTML = `
      <div>
        <span class="sc-ticker">${sc.ticker}</span>
        <div class="sc-meta">${new Date(sc.ts).toLocaleTimeString()}</div>
      </div>
      <div style="display:flex;align-items:center;justify-content:space-between">
        <span class="sc-score" style="color:${scoreColor}">${sc.result.total}</span>
        <div style="text-align:right">
          ${deltaHtml}
          <div class="sc-label" style="color:${scoreColor}">${sc.result.action}</div>
        </div>
      </div>`;
    el.onclick = () => loadScenario(i);
    list.appendChild(el);
  });
  list.scrollLeft = list.scrollWidth;
}

function loadScenario(i) {
  activeScenarioIdx = i;
  renderScenarios();
  const sc = scenarios[i];
  // Restore params
  Object.assign(PARAMS, sc.params);
  // Update param sliders
  document.getElementById('pmVolume').value = PARAMS.SCORE_MAX_VOLUME;
  document.getElementById('pmInsider').value = PARAMS.SCORE_MAX_INSIDER;
  document.getElementById('pmGate').value = PARAMS.CONVICTION_GATE;
  document.getElementById('pmHigh').value = PARAMS.CONVICTION_HIGH;
  document.getElementById('pmElite').value = PARAMS.CONVICTION_ELITE;
  syncParams();
  renderOutput(sc.result);
}

